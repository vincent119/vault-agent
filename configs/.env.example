APP_ENV=dev
APP_PORT=10000
# Vault：K8s 部署請用 Kubernetes 認證，設 VAULT_AUTH_K8S_PATH、VAULT_AUTH_K8S_ROLE（勿寫 VAULT_TOKEN）。
# 僅本機用 Vault dev server 時可設 VAULT_ADDRESS=http://127.0.0.1:8200 與 VAULT_TOKEN=...（勿提交真實 token）
# 例（K8s）：VAULT_ADDRESS=https://vault.imdevs.net VAULT_AUTH_K8S_PATH=im-devops-eks VAULT_AUTH_K8S_ROLE=vault-agent
